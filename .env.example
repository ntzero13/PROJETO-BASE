APP_NAME="Base SaaS Vistorias"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://admin.sistema.test

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=vistoria_central
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

CENTRAL_DB_HOST=${DB_HOST}
CENTRAL_DB_PORT=${DB_PORT}
CENTRAL_DB_DATABASE=${DB_DATABASE}
CENTRAL_DB_USERNAME=${DB_USERNAME}
CENTRAL_DB_PASSWORD=${DB_PASSWORD}
CENTRAL_DB_SSLMODE=${DB_SSLMODE}

TENANT_DB_HOST=${DB_HOST}
TENANT_DB_PORT=${DB_PORT}
TENANT_DB_DATABASE=postgres
TENANT_DB_USERNAME=${DB_USERNAME}
TENANT_DB_PASSWORD=${DB_PASSWORD}
TENANT_DB_SSLMODE=${DB_SSLMODE}

CENTRAL_DOMAINS=admin.sistema.test,master.sistema.test,localhost,127.0.0.1
CENTRAL_ADMIN_NAME="Administrador Master"
CENTRAL_ADMIN_EMAIL=admin@sistema.test
CENTRAL_ADMIN_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
